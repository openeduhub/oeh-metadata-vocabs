{"componentChunkName":"component---src-components-concept-jsx","path":"/w3id.org/openeduhub/vocabs/oeh-topics/8b3bc77e-07fa-4bbe-add1-ae449c3679ee.html","result":{"pageContext":{"node":{"id":"http://w3id.org/openeduhub/vocabs/oeh-topics/8b3bc77e-07fa-4bbe-add1-ae449c3679ee","type":"Concept","prefLabel":{"de":"Die Historische Entwicklung des Periodensystems","en":null,"uk":null},"altLabel":null,"hiddenLabel":null,"definition":{"de":"Ausgehend von ähnlichen Reaktionen verschiedener Elemente entwickelten verschiedene Wissenschaftler, darunter Mendelejew und Meyer, Vorschläge für eine Ordnung der Elemente in einer gemeinsamen Tabelle. Erst die Idee, die Elemente grob nach zunehmender Masse zu ordnen und Elemente mit ähnlichen Eigenschaften untereinander zu notieren, ebnete den Weg zum Periodensystem der Elemente, wie wir es heute kennen - und das weitgehend ohne Kenntnis des zugrunde liegenden Atombaus, wie wir sie heute haben.","en":null,"uk":null},"note":null,"changeNote":null,"editorialNote":null,"historyNote":null,"scopeNote":null,"notation":["8b3bc77e-07fa-4bbe-add1-ae449c3679ee"],"example":null,"narrower":[],"narrowerTransitive":[],"broader":{"id":"http://w3id.org/openeduhub/vocabs/oeh-topics/c0b6ce90-44c3-46dc-ae3e-2741d78d9294","prefLabel":{"de":"Das Periodensystem","en":null,"uk":null}},"broaderTransitive":null,"related":[],"relatedMatch":[{"id":"http://w3id.org/openeduhub/vocabs/discipline/100"}],"broadMatch":null,"narrowMatch":null,"closeMatch":null,"exactMatch":null,"inScheme":[{"id":"http://w3id.org/openeduhub/vocabs/oeh-topics/5e40e372-735c-4b17-bbf7-e827a5702b57","title":{"de":"Taxonomie von Lehrplanthemen in WirLernenOnline","en":null,"uk":null}}],"inSchemeAll":[{"id":"http://w3id.org/openeduhub/vocabs/oeh-topics/5e40e372-735c-4b17-bbf7-e827a5702b57"}],"topConceptOf":[],"deprecated":null,"isReplacedBy":null,"url":null},"collections":[],"customDomain":""}},"staticQueryHashes":["1805648281","3649515864","63159454"],"slicesMap":{}}