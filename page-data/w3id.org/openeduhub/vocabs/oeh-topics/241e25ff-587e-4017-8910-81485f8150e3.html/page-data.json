{"componentChunkName":"component---src-components-concept-jsx","path":"/w3id.org/openeduhub/vocabs/oeh-topics/241e25ff-587e-4017-8910-81485f8150e3.html","result":{"pageContext":{"node":{"id":"http://w3id.org/openeduhub/vocabs/oeh-topics/241e25ff-587e-4017-8910-81485f8150e3","type":"Concept","prefLabel":{"de":"Homophonie","en":null,"uk":null},"altLabel":null,"hiddenLabel":null,"definition":{"de":"Homophonie ist eine musikalische Satzstruktur, bei der mehrere Stimmen oder Instrumente synchron denselben rhythmischen Verlauf haben, während ihre melodischen Linien unabhängig voneinander sind. Im Gegensatz zur Polyphonie, bei der die Stimmen unabhängige Melodien erzeugen, tritt bei der Homophonie eine klare Akkordstruktur auf, bei der alle Klänge gleichzeitig auf denselben Akkord oder dieselbe Akkordfolge abzielen. \nHomophonie wirkt deshalb oft sehr harmonisch.","en":null,"uk":null},"note":null,"changeNote":null,"editorialNote":null,"historyNote":null,"scopeNote":null,"notation":["241e25ff-587e-4017-8910-81485f8150e3"],"example":null,"narrower":[],"narrowerTransitive":[],"broader":{"id":"http://w3id.org/openeduhub/vocabs/oeh-topics/2898e432-ffb0-419f-9194-52f89c0338d9","prefLabel":{"de":"Satztechniken","en":null,"uk":null}},"broaderTransitive":null,"related":[],"relatedMatch":[{"id":"http://w3id.org/openeduhub/vocabs/discipline/420"}],"broadMatch":null,"narrowMatch":null,"closeMatch":null,"exactMatch":null,"inScheme":[{"id":"http://w3id.org/openeduhub/vocabs/oeh-topics/5e40e372-735c-4b17-bbf7-e827a5702b57","title":{"de":"Taxonomie von Lehrplanthemen in WirLernenOnline","en":null,"uk":null}}],"inSchemeAll":[{"id":"http://w3id.org/openeduhub/vocabs/oeh-topics/5e40e372-735c-4b17-bbf7-e827a5702b57"}],"topConceptOf":[],"deprecated":null,"iconName":null,"isReplacedBy":null,"url":null},"collections":[],"customDomain":""}},"staticQueryHashes":["1805648281","3649515864","63159454"],"slicesMap":{}}