@base <http://w3id.org/openeduhub/vocabs/quality_neutrality/> .
@prefix dct: <http://purl.org/dc/terms/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<> a skos:ConceptScheme ;
    dct:title "Neutralitätsqualität"@de ;
    dct:title "Neutrality Quality"@en ;
    dct:description "Bewertung der inhaltlichen Neutralität einer Lernressource auf einer Skala von 0 (manipulativ) bis 5 (neutrale Formulierung, unabhängiger Ersteller)."@de ;
    dct:description "Assessment of the content neutrality of a learning resource on a scale from 0 (manipulative) to 5 (neutral wording, independent creator)."@en ;
    dct:creator "<https://wirlernenonline.de>" ;
    dct:created "2026-03-26"^^xsd:date ;
    dct:modified "2026-03-26"^^xsd:date ;
    dct:license <http://creativecommons.org/publicdomain/zero/1.0/> ;
    skos:hasTopConcept <0>, <1>, <2>, <3>, <4>, <5> .

<0> a skos:Concept ;
    skos:prefLabel "manipulativ"@de ;
    skos:prefLabel "manipulative"@en ;
    skos:definition "Der Inhalt ist darauf ausgelegt, Nutzende zu manipulieren oder zu beeinflussen, ohne dies transparent zu machen."@de ;
    skos:definition "The content is designed to manipulate or unduly influence users without making this transparent."@en ;
    skos:notation "0" ;
    skos:topConceptOf <> .

<1> a skos:Concept ;
    skos:prefLabel "✰ unneutral"@de ;
    skos:prefLabel "✰ non-neutral"@en ;
    skos:definition "Der Inhalt ist erkennbar einseitig oder voreingenommen, ohne dass dies kenntlich gemacht wird."@de ;
    skos:definition "The content is noticeably one-sided or biased without this being made apparent."@en ;
    skos:notation "1" ;
    skos:topConceptOf <> .

<2> a skos:Concept ;
    skos:prefLabel "✰✰ ideologisch eingefärbt, aber korrekter Inhalt"@de ;
    skos:prefLabel "✰✰ ideologically biased but factually correct"@en ;
    skos:definition "Der Inhalt ist ideologisch geprägt, die sachlichen Aussagen sind jedoch korrekt."@de ;
    skos:definition "The content is ideologically coloured, but the factual statements are correct."@en ;
    skos:notation "2" ;
    skos:topConceptOf <> .

<3> a skos:Concept ;
    skos:prefLabel "✰✰✰ ideologisch eingefärbt, aber transparent"@de ;
    skos:prefLabel "✰✰✰ ideologically biased but transparent"@en ;
    skos:definition "Der Inhalt hat eine ideologische Färbung, diese wird jedoch offen kommuniziert und für Nutzende nachvollziehbar gemacht."@de ;
    skos:definition "The content has an ideological bias, but this is openly communicated and made transparent to users."@en ;
    skos:notation "3" ;
    skos:topConceptOf <> .

<4> a skos:Concept ;
    skos:prefLabel "✰✰✰✰ neutrale Formulierung"@de ;
    skos:prefLabel "✰✰✰✰ neutral wording"@en ;
    skos:definition "Der Inhalt ist neutral formuliert und vermeidet einseitige oder wertende Darstellungen."@de ;
    skos:definition "The content is worded neutrally and avoids one-sided or evaluative representations."@en ;
    skos:notation "4" ;
    skos:topConceptOf <> .

<5> a skos:Concept ;
    skos:prefLabel "✰✰✰✰✰ neutrale Formulierung, unabhängiger Ersteller"@de ;
    skos:prefLabel "✰✰✰✰✰ neutral wording, independent creator"@en ;
    skos:definition "Der Inhalt ist neutral formuliert und stammt von einem unabhängigen Ersteller ohne erkennbare Interessenkonflikte."@de ;
    skos:definition "The content is worded neutrally and originates from an independent creator without discernible conflicts of interest."@en ;
    skos:notation "5" ;
    skos:topConceptOf <> .
