{"id":"http://w3id.org/openeduhub/vocabs/quality_didactics/","type":"ConceptScheme","title":{"de":"Didaktische Qualität","en":"Didactic Quality"},"description":{"de":"Bewertung der didaktischen und methodischen Qualität einer Lernressource auf einer Skala von 0 (Methodik unangemessen) bis 5 (moderne, sehr gute Methodik).","en":"Assessment of the didactic and methodological quality of a learning resource on a scale from 0 (inappropriate methodology) to 5 (modern, very good methodology)."},"license":{"id":"http://creativecommons.org/publicdomain/zero/1.0/"},"hasTopConcept":[{"id":"http://w3id.org/openeduhub/vocabs/quality_didactics/0","notation":["0"],"prefLabel":{"de":"Methodik unangemessen","en":"inappropriate methodology"},"definition":{"de":"Die eingesetzte Methodik ist unangemessen und unterstützt den Lernprozess nicht.","en":"The methodology used is inappropriate and does not support the learning process."}},{"id":"http://w3id.org/openeduhub/vocabs/quality_didactics/1","notation":["1"],"prefLabel":{"de":"✰ Methodik ausreichend","en":"✰ sufficient methodology"},"definition":{"de":"Die Methodik ist ausreichend, weist jedoch erhebliche Schwächen auf.","en":"The methodology is sufficient but shows significant weaknesses."}},{"id":"http://w3id.org/openeduhub/vocabs/quality_didactics/2","notation":["2"],"prefLabel":{"de":"✰✰ angemessene Methodik","en":"✰✰ appropriate methodology"},"definition":{"de":"Die Methodik ist angemessen und unterstützt den Lernprozess in ausreichendem Maße.","en":"The methodology is appropriate and sufficiently supports the learning process."}},{"id":"http://w3id.org/openeduhub/vocabs/quality_didactics/3","notation":["3"],"prefLabel":{"de":"✰✰✰ gute Methodik","en":"✰✰✰ good methodology"},"definition":{"de":"Die Methodik ist gut und fördert den Lernprozess effektiv.","en":"The methodology is good and effectively promotes the learning process."}},{"id":"http://w3id.org/openeduhub/vocabs/quality_didactics/4","notation":["4"],"prefLabel":{"de":"✰✰✰✰ moderne, gute Methodik","en":"✰✰✰✰ modern, good methodology"},"definition":{"de":"Die Methodik ist modern und gut, setzt aktuelle didaktische Ansätze sinnvoll ein.","en":"The methodology is modern and good, making meaningful use of current didactic approaches."}},{"id":"http://w3id.org/openeduhub/vocabs/quality_didactics/5","notation":["5"],"prefLabel":{"de":"✰✰✰✰✰ moderne, sehr gute Methodik","en":"✰✰✰✰✰ modern, very good methodology"},"definition":{"de":"Die Methodik ist modern und hervorragend, setzt aktuelle didaktische Ansätze optimal ein und fördert nachhaltiges Lernen.","en":"The methodology is modern and outstanding, optimally applying current didactic approaches and fostering sustainable learning."}}],"@context":{"@version":1.1,"id":"@id","type":"@type","@vocab":"http://www.w3.org/2004/02/skos/core#","xsd":"http://www.w3.org/2001/XMLSchema#","dct":"http://purl.org/dc/terms/","dc":"http://purl.org/dc/elements/1.1/","oeh":"http://w3id.org/openeduhub/vocab#","schema":"https://schema.org/","vann":"http://purl.org/vocab/vann/","ldp":"http://www.w3.org/ns/ldp#","owl":"http://www.w3.org/2002/07/owl#","title":{"@id":"dct:title","@container":"@language"},"dc:title":{"@id":"dc:title","@container":"@language"},"dc:description":{"@id":"dc:description","@container":"@language"},"description":{"@id":"dct:description","@container":"@language"},"license":{"@id":"dct:license","@container":"@language"},"issued":{"@id":"dct:issued","@type":"xsd:date"},"created":{"@id":"dct:created","@type":"xsd:date"},"modified":{"@id":"dct:modified","@type":"xsd:date"},"creator":"dct:creator","publisher":"dct:publisher","preferredNamespacePrefix":"vann:preferredNamespacePrefix","preferredNamespaceUri":"vann:preferredNamespaceUri","isBasedOn":"schema:isBasedOn","source":"dct:source","prefLabel":{"@container":"@language"},"altLabel":{"@container":["@language","@set"]},"hiddenLabel":{"@container":["@language","@set"]},"definition":{"@container":"@language"},"note":{"@container":["@language","@set"]},"changeNote":{"@container":["@language","@set"]},"editorialNote":{"@container":["@language","@set"]},"historyNote":{"@container":["@language","@set"]},"scopeNote":{"@container":["@language","@set"]},"notation":{"@container":"@set"},"example":{"@container":"@language"},"narrower":{"@container":"@set"},"related":{"@container":"@set"},"relatedMatch":{"@container":"@set"},"narrowerTransitive":{"@container":"@set"},"broaderTransitive":{"@container":"@set"},"broadMatch":{"@container":"@set"},"narrowMatch":{"@container":"@set"},"closeMatch":{"@container":"@set"},"exactMatch":{"@container":"@set"},"hasTopConcept":{"@container":"@set"},"inScheme":{"@container":"@set"},"topConceptOf":{"@container":"@set"},"deprecated":{"@id":"owl:deprecated","@type":"xsd:boolean"},"isReplacedBy":{"@id":"dct:isReplacedBy","@container":"@set"},"url":{"@id":"schema:url","@container":"@set"},"iconName":"oeh:iconName"}}