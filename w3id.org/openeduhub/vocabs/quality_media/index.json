{"id":"http://w3id.org/openeduhub/vocabs/quality_media/","type":"ConceptScheme","title":{"de":"Mediale Qualität","en":"Media Quality"},"description":{"de":"Bewertung der medialen Qualität einer Lernressource auf einer Skala von 0 (medial unpassend) bis 5 (medial hervorragend).","en":"Assessment of the media quality of a learning resource on a scale from 0 (medially unsuitable) to 5 (medially outstanding)."},"license":{"id":"http://creativecommons.org/publicdomain/zero/1.0/"},"hasTopConcept":[{"id":"http://w3id.org/openeduhub/vocabs/quality_media/0","notation":["0"],"prefLabel":{"de":"Medial unpassend","en":"medially unsuitable"},"definition":{"de":"Die Aufbereitung des Inhalts ist medial unpassend und unterstützt das Lernen nicht.","en":"The media presentation of the content is unsuitable and does not support learning."}},{"id":"http://w3id.org/openeduhub/vocabs/quality_media/1","notation":["1"],"prefLabel":{"de":"✰ Medial schwierig","en":"✰ medially difficult"},"definition":{"de":"Die mediale Aufbereitung ist schwierig und erschwert die Nutzung der Lernressource.","en":"The media presentation is difficult and hinders the use of the learning resource."}},{"id":"http://w3id.org/openeduhub/vocabs/quality_media/2","notation":["2"],"prefLabel":{"de":"✰✰ Medial ausreichend, aber suboptimal","en":"✰✰ medially sufficient but suboptimal"},"definition":{"de":"Die mediale Aufbereitung ist ausreichend, weist aber deutliche Verbesserungspotenziale auf.","en":"The media presentation is sufficient but shows clear potential for improvement."}},{"id":"http://w3id.org/openeduhub/vocabs/quality_media/3","notation":["3"],"prefLabel":{"de":"✰✰✰ Medial passend","en":"✰✰✰ medially suitable"},"definition":{"de":"Die mediale Aufbereitung ist passend und unterstützt das Lernen angemessen.","en":"The media presentation is suitable and adequately supports learning."}},{"id":"http://w3id.org/openeduhub/vocabs/quality_media/4","notation":["4"],"prefLabel":{"de":"✰✰✰✰ Medial gut","en":"✰✰✰✰ medially good"},"definition":{"de":"Die mediale Aufbereitung ist gut und fördert das Lernen effektiv.","en":"The media presentation is good and effectively promotes learning."}},{"id":"http://w3id.org/openeduhub/vocabs/quality_media/5","notation":["5"],"prefLabel":{"de":"✰✰✰✰✰ Medial hervorragend","en":"✰✰✰✰✰ medially outstanding"},"definition":{"de":"Die mediale Aufbereitung ist hervorragend und unterstützt das Lernen optimal.","en":"The media presentation is outstanding and optimally supports learning."}}],"@context":{"@version":1.1,"id":"@id","type":"@type","@vocab":"http://www.w3.org/2004/02/skos/core#","xsd":"http://www.w3.org/2001/XMLSchema#","dct":"http://purl.org/dc/terms/","dc":"http://purl.org/dc/elements/1.1/","oeh":"http://w3id.org/openeduhub/vocab#","schema":"https://schema.org/","vann":"http://purl.org/vocab/vann/","ldp":"http://www.w3.org/ns/ldp#","owl":"http://www.w3.org/2002/07/owl#","title":{"@id":"dct:title","@container":"@language"},"dc:title":{"@id":"dc:title","@container":"@language"},"dc:description":{"@id":"dc:description","@container":"@language"},"description":{"@id":"dct:description","@container":"@language"},"license":{"@id":"dct:license","@container":"@language"},"issued":{"@id":"dct:issued","@type":"xsd:date"},"created":{"@id":"dct:created","@type":"xsd:date"},"modified":{"@id":"dct:modified","@type":"xsd:date"},"creator":"dct:creator","publisher":"dct:publisher","preferredNamespacePrefix":"vann:preferredNamespacePrefix","preferredNamespaceUri":"vann:preferredNamespaceUri","isBasedOn":"schema:isBasedOn","source":"dct:source","prefLabel":{"@container":"@language"},"altLabel":{"@container":["@language","@set"]},"hiddenLabel":{"@container":["@language","@set"]},"definition":{"@container":"@language"},"note":{"@container":["@language","@set"]},"changeNote":{"@container":["@language","@set"]},"editorialNote":{"@container":["@language","@set"]},"historyNote":{"@container":["@language","@set"]},"scopeNote":{"@container":["@language","@set"]},"nota